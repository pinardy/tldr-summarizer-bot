# Copy to .env and fill in.
# Telegram bot token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=

# Your chat ID: message your bot once, then check
# https://api.telegram.org/bot<TOKEN>/getUpdates -> message.chat.id
TELEGRAM_CHAT_ID=

# Optional: opencode API key (https://opencode.ai — copy from the Zen console)
# for AI key-points summarization. Works with an opencode Go subscription.
# Leave empty to send the full parsed story list instead.
OPENCODE_API_KEY=

# Optional: model override. Must be a chat/completions model on your plan.
# Go plan options: deepseek-v4-flash (default), deepseek-v4-pro, glm-5.2,
# glm-5.1, kimi-k2.7-code, kimi-k2.6, mimo-v2.5, mimo-v2.5-pro.
# (MiniMax/Qwen models use a different endpoint and won't work here.)
#OPENCODE_MODEL=deepseek-v4-flash

# Optional: endpoint override. Default is the Go subscription endpoint;
# pay-as-you-go Zen users should set:
#OPENCODE_API_URL=https://opencode.ai/zen/v1/chat/completions
